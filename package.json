{
  "name": "durion-positivity-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "a11y:smoke": "node scripts/a11y/smoke-routes.mjs",
    "a11y:smoke:strict": "A11Y_FAIL_ON_IMPACT=serious node scripts/a11y/smoke-routes.mjs",
    "i18n:check:missing": "node scripts/i18n/check-missing-keys.mjs",
    "i18n:pseudo:generate": "node scripts/i18n/generate-pseudo-locale.mjs",
    "i18n:pseudo:check": "node scripts/i18n/generate-pseudo-locale.mjs --check",
    "i18n:check": "npm run i18n:check:missing && npm run i18n:pseudo:check",
    "serve:ssr:durion-positivity-frontend": "node dist/durion-positivity-frontend/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.5",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/uuid": "^10.0.0",
    "axe-core": "^4.11.1",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
